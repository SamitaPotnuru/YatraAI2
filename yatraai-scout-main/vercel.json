{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/predict",
      "destination": "https://yatra-ai-backend-i5r17e.leapcell.dev/predict"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
